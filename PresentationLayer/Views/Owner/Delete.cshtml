@model Business_Layer.Owner
@{
    ViewData["Title"] = "Delete Owner";
}

<h1 class="h3 mb-3 text-danger">Delete Owner</h1>

<div class="alert alert-warning">Are you sure you want to delete this owner?</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>
            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd>
            <dt class="col-sm-3">Pets</dt>
            <dd class="col-sm-9">@Model.Pets.Count</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
