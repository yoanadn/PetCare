@model Business_Layer.Pet
@{
    ViewData["Title"] = "Pet Details";
}

<h1 class="h3 mb-3">Pet Details</h1>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Species</dt>
            <dd class="col-sm-9">@Model.Species</dd>
            <dt class="col-sm-3">Breed</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Breed) ? "-" : Model.Breed)</dd>
            <dt class="col-sm-3">Birth Date</dt>
            <dd class="col-sm-9">@(Model.BirthDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
            <dt class="col-sm-3">Weight</dt>
            <dd class="col-sm-9">@(Model.Weight.HasValue ? $"{Model.Weight:0.##} kg" : "-")</dd>
            <dt class="col-sm-3">Owner</dt>
            <dd class="col-sm-9">@Model.Owner?.FullName</dd>
        </dl>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-outline-secondary">Back</a>
