@model Business_Layer.Pet
@{
    ViewData["Title"] = "Delete Pet";
}

<h1 class="h3 mb-3 text-danger">Delete Pet</h1>

<div class="alert alert-warning">Are you sure you want to delete this pet?</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Species</dt>
            <dd class="col-sm-9">@Model.Species</dd>
            <dt class="col-sm-3">Owner</dt>
            <dd class="col-sm-9">@Model.Owner?.FullName</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
