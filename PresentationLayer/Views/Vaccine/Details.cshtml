@model Business_Layer.Vaccine
@{
    ViewData["Title"] = "Vaccine Details";
}

<h1 class="h3 mb-3">Vaccine Details</h1>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.Name</dd>
            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.Type</dd>
            <dt class="col-sm-3">Date Given</dt>
            <dd class="col-sm-9">@Model.DateGiven.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Next Dose Date</dt>
            <dd class="col-sm-9">@(Model.NextDoseDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
        </dl>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
<a asp-action="Index" class="btn btn-outline-secondary">Back</a>
