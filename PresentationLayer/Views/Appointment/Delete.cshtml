@model Business_Layer.Appointment
@{
    ViewData["Title"] = "Delete Appointment";
}

<h1 class="h3 mb-3 text-danger">Delete Appointment</h1>

<div class="alert alert-warning">Are you sure you want to delete this appointment?</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.Name</dd>
            <dt class="col-sm-3">Date & Time</dt>
            <dd class="col-sm-9">@Model.DateTime.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt class="col-sm-3">Location</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Location) ? "-" : Model.Location)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
