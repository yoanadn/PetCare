@model Business_Layer.VetVisit
@{
    ViewData["Title"] = "Delete Vet Visit";
}

<h1 class="h3 mb-3 text-danger">Delete Vet Visit</h1>

<div class="alert alert-warning">Are you sure you want to delete this vet visit?</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Pet</dt>
            <dd class="col-sm-9">@Model.Pet?.Name</dd>
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-3">Reason</dt>
            <dd class="col-sm-9">@Model.Reason</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
