@model IEnumerable<Business_Layer.VetVisit>
@{
    ViewData["Title"] = "Vet Visits";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Vet Visits</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> New Vet Visit</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Pet</th>
                    <th>Date</th>
                    <th>Reason</th>
                    <th>Vet</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Pet?.Name</td>
                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                    <td>@item.Reason</td>
                    <td>@(string.IsNullOrWhiteSpace(item.VetName) ? "-" : item.VetName)</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
